# Copy this file to `.env`, then fill your own token.
# Do not commit `.env`.

# SiliconFlow / 硅基流动 OpenAI-compatible configuration.
# Official docs: https://api-docs.siliconflow.cn/docs/api/chat-completions-post
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1

# Use the exact model name shown in your SiliconFlow console. For --llm-review,
# it must be a vision-language model that accepts image_url data URLs. A text-only
# model can still be used for text tasks, but cannot perform this experiment.
LLM_MODEL=

# Some SiliconFlow VLMs, including zai-org/GLM-4.5V, support image input but
# do not support response_format={"type":"json_object"}. Keep this false for
# GLM-4.5V; the prompt still asks the model to return JSON and the parser checks it.
LLM_RESPONSE_FORMAT_JSON=false

LLM_TIMEOUT=30
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=400
